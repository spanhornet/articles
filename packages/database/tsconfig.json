{
  "extends": "@repo/typescript-config/nextjs.json",
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": ["dist", "build", "node_modules"],
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    "module": "ES2022",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
  }
}